# Redis image/version
REDIS_IMAGE_TAG=7-alpine

# Container naming
REDIS_CONTAINER_NAME=logonservice-redis

# Host port mapped to container 6379
REDIS_HOST_PORT=6379

# Optional auth password (recommended for shared/server env)
# Leave empty for local-only dev if you want.
REDIS_PASSWORD=

# Storage mount strategy:
# 1) Named Docker volume (portable default):
#    REDIS_DATA_MOUNT=redis_data
# 2) Local filesystem path (per-developer machine):
#    REDIS_DATA_MOUNT=./data
# 3) Server/remote mounted path later:
#    REDIS_DATA_MOUNT=/mnt/redis/logonservice
REDIS_DATA_MOUNT=redis_data
