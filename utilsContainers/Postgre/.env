# Postgres image/version
POSTGRES_IMAGE_TAG=16-alpine

# Container naming
POSTGRES_CONTAINER_NAME=logonservice-postgres

# DB bootstrap credentials (dev defaults)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=logonservice

# Host port mapped to container 5432
POSTGRES_HOST_PORT=5432

# Storage mount strategy:
# 1) Named Docker volume (portable default):
#    POSTGRES_DATA_MOUNT=postgres_data
# 2) Local filesystem path (per-developer machine):
#    POSTGRES_DATA_MOUNT=./data
# 3) Server/remote mounted path later:
#    POSTGRES_DATA_MOUNT=/mnt/postgres/logonservice
POSTGRES_DATA_MOUNT=postgres_data
