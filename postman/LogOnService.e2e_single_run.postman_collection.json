{
  "info": {
    "_postman_id": "ef8d194b-6c65-4129-a804-f1995d2412ac",
    "name": "LogOnService E2E Single Run",
    "description": "Single-request end-to-end flow: login -> me -> sessions -> refresh -> logout.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "RUN E2E FLOW",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const baseUrl = pm.environment.get('base_url') || 'http://127.0.0.1:8000';",
              "const loginIdentifier = pm.environment.get('login_identifier');",
              "const loginPassword = pm.environment.get('login_password');",
              "",
              "if (!loginIdentifier || !loginPassword) {",
              "  throw new Error('Set login_identifier and login_password in environment before running E2E flow.');",
              "}",
              "",
              "function readSetCookieCookies(response) {",
              "  const cookies = {};",
              "  const headerValues = response.headers.all()",
              "    .filter(h => h.key.toLowerCase() === 'set-cookie')",
              "    .map(h => h.value);",
              "  headerValues.forEach(raw => {",
              "    const m = raw.match(/^([^=]+)=([^;]*)/);",
              "    if (m) cookies[m[1]] = m[2];",
              "  });",
              "  return cookies;",
              "}",
              "",
              "function mergeCookies(current, incoming) {",
              "  return Object.assign({}, current || {}, incoming || {});",
              "}",
              "",
              "function cookieHeader(cookies) {",
              "  return Object.entries(cookies).map(([k, v]) => `${k}=${v}`).join('; ');",
              "}",
              "",
              "function assertStatus(label, err, res, expected) {",
              "  pm.test(`${label} status is ${expected}`, function () {",
              "    pm.expect(err, `${label} request error`).to.equal(null);",
              "    pm.expect(res.code, `${label} status`).to.equal(expected);",
              "  });",
              "  if (err) throw err;",
              "  if (res.code !== expected) {",
              "    throw new Error(`${label} failed with status ${res.code}: ${res.text()}`);",
              "  }",
              "}",
              "",
              "pm.sendRequest({",
              "  url: `${baseUrl}/auth/login`,",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      email_or_username: loginIdentifier,",
              "      password: loginPassword",
              "    })",
              "  }",
              "}, function (loginErr, loginRes) {",
              "  assertStatus('login', loginErr, loginRes, 200);",
              "",
              "  const loginJson = loginRes.json();",
              "  if (loginJson && loginJson.mfa_required) {",
              "    throw new Error('MFA user detected. Use non-MFA test user for this single-run flow.');",
              "  }",
              "",
              "  let cookies = readSetCookieCookies(loginRes);",
              "  if (!cookies.csrf_token || !cookies.access_token || !cookies.refresh_token) {",
              "    throw new Error('Login did not return expected auth cookies.');",
              "  }",
              "",
              "  pm.environment.set('csrf_token', cookies.csrf_token);",
              "  pm.environment.set('access_token', cookies.access_token);",
              "  pm.environment.set('refresh_token', cookies.refresh_token);",
              "",
              "  const authCookieHeader = cookieHeader(cookies);",
              "",
              "  pm.sendRequest({",
              "    url: `${baseUrl}/users/me`,",
              "    method: 'GET',",
              "    header: { 'Cookie': authCookieHeader }",
              "  }, function (meErr, meRes) {",
              "    assertStatus('users/me', meErr, meRes, 200);",
              "",
              "    pm.sendRequest({",
              "      url: `${baseUrl}/users/me/sessions`,",
              "      method: 'GET',",
              "      header: { 'Cookie': authCookieHeader }",
              "    }, function (sessionsErr, sessionsRes) {",
              "      assertStatus('users/me/sessions', sessionsErr, sessionsRes, 200);",
              "",
              "      pm.sendRequest({",
              "        url: `${baseUrl}/auth/refresh`,",
              "        method: 'POST',",
              "        header: {",
              "          'Cookie': authCookieHeader,",
              "          'X-CSRF-Token': cookies.csrf_token",
              "        }",
              "      }, function (refreshErr, refreshRes) {",
              "        assertStatus('auth/refresh', refreshErr, refreshRes, 200);",
              "",
              "        cookies = mergeCookies(cookies, readSetCookieCookies(refreshRes));",
              "        const refreshedCookieHeader = cookieHeader(cookies);",
              "",
              "        pm.sendRequest({",
              "          url: `${baseUrl}/auth/logout`,",
              "          method: 'POST',",
              "          header: {",
              "            'Cookie': refreshedCookieHeader,",
              "            'X-CSRF-Token': cookies.csrf_token",
              "          }",
              "        }, function (logoutErr, logoutRes) {",
              "          assertStatus('auth/logout', logoutErr, logoutRes, 200);",
              "          pm.test('E2E single run completed', function () {",
              "            pm.expect(true).to.equal(true);",
              "          });",
              "        });",
              "      });",
              "    });",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    }
  ]
}
