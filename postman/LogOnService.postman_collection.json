          "name": "GET /users/me/sessions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "if (Array.isArray(data.sessions)) {",
                  "  const target = data.sessions.find(s => !s.is_current) || data.sessions[0];",
                  "  if (target && target.jti) pm.environment.set('session_jti', target.jti);",
                  "}",
                  "pm.test('Sessions request executed', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                  "});"
                ]
              }
            }
