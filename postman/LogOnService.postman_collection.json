          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "if (data.mfa_token) pm.environment.set('mfa_token', data.mfa_token);",
                  "if (data.user && data.user.id) pm.environment.set('current_user_id', data.user.id);",
                  "pm.test('Login request executed', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
