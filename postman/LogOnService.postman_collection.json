{
  "info": {
    "_postman_id": "7df391a8-4e5c-4f19-a8d1-8bbcf2a56f8f",
    "name": "LogOnService API",
    "description": "Cookie-based auth flow with CSRF handling for LogOnService.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const method = (pm.request.method || '').toUpperCase();",
          "const mutating = ['POST','PUT','PATCH','DELETE'].includes(method);",
          "if (mutating) {",
          "  const csrf = pm.cookies.get('csrf_token') || pm.environment.get('csrf_token');",
          "  if (csrf) {",
          "    pm.request.headers.upsert({ key: 'X-CSRF-Token', value: csrf });",
          "  }",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const setCookies = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie').map(h => h.value);",
          "for (const raw of setCookies) {",
          "  const match = raw.match(/^([^=]+)=([^;]*)/);",
          "  if (!match) continue;",
          "  const key = match[1];",
          "  const value = match[2];",
          "  if (key === 'csrf_token') pm.environment.set('csrf_token', value);",
          "  if (key === 'access_token') pm.environment.set('access_token', value);",
          "  if (key === 'refresh_token') pm.environment.set('refresh_token', value);",
          "}"
        ]
      }
    }
  ],
