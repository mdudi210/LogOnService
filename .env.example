# Core runtime (required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/logonservice
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-very-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET_KEY=replace-with-very-long-random-refresh-secret-min-32-chars
TOTP_ENCRYPTION_KEY=replace-with-dedicated-totp-encryption-key
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Token & cookie policy
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=strict
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# Rate limiter
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_KEY_PREFIX=rl
RISK_MEDIUM_SCORE_THRESHOLD=40
RISK_HIGH_SCORE_THRESHOLD=70
ALERT_EMAIL_TO=
SECURITY_ALERT_EMAIL=
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_WEBHOOK_FORMAT=auto
ALERT_MIN_SEVERITY=medium

# Google OAuth (authorization-code flow)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=openid email profile
OAUTH_STATE_TTL_SECONDS=600

# Optional local Docker host-port override (avoids conflicts with local Redis)
REDIS_HOST_PORT=6380
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# SMTP (free providers: Gmail app password / Mailtrap)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@logonservices.local
SMTP_STARTTLS=true
