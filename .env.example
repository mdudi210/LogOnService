# Core runtime (required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/logonservice
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-very-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET_KEY=replace-with-very-long-random-refresh-secret-min-32-chars
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Token & cookie policy
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=strict
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# Rate limiter
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_KEY_PREFIX=rl

# SMTP (free providers: Gmail app password / Mailtrap)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@logonservice.local
SMTP_STARTTLS=true
