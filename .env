DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/logonservice
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=dev-access-secret-key-minimum-32-characters-long
JWT_REFRESH_SECRET_KEY=dev-refresh-secret-key-minimum-32-characters
TOTP_ENCRYPTION_KEY=dev-totp-encryption-key-minimum-32-characters
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=strict
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_KEY_PREFIX=rl
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@logonservice.local
SMTP_STARTTLS=true
SECURITY_ALERTS_ENABLED=true
SECURITY_ALERT_EMAIL=
SECURITY_ALERT_EVENT_TYPES=TOKEN_REUSE_DETECTED,PASSWORD_CHANGED,MFA_ENABLED
